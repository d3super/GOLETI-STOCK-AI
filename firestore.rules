// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId} (Auth UID)
// Fields:
//   - uid: string (required) - Auth UID
//   - email: string (required) - User email
//   - displayName: string (optional)
//   - photoURL: string (optional)
//   - plan: string (required, enum: ['free', 'standard', 'pro'])
//   - analysisCount: number (optional)
//   - lastAnalysisDate: string (optional)
//   - createdAt: timestamp (optional)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.get('email', '') == "d3super@gmail.com" && request.auth.token.get('email_verified', false) == true) ||
          // Only check Firestore if the user is NOT the hardcoded admin
          (request.auth.token.get('email', '') != "d3super@gmail.com" && 
           exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('plan', 'none') == 'admin')
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'plan']) &&
             data.uid is string && data.uid.size() < 128 &&
             data.email is string && data.email.size() < 256 &&
             data.plan in ['free', 'standard', 'pro', 'admin'] &&
             (!('analysisCount' in data) || data.analysisCount is number) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 1024));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read their own profile. Admins can read any profile.
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Users can create their own profile as 'free' plan. Admins can create any.
      allow create: if isAuthenticated() && 
                    isValidUser(request.resource.data) && 
                    (
                      (request.auth.uid == userId && request.resource.data.plan == 'free') || 
                      isAdmin()
                    );
      
      // FOR DEMO PURPOSES: Users can update their own plan to 'standard' or 'pro'.
      // BUT: Only Admins can set/keep the 'admin' plan.
      allow update: if isAuthenticated() && 
                    isValidUser(request.resource.data) && 
                    request.auth.uid == userId &&
                    (request.resource.data.plan != 'admin' || isAdmin());
                    
      allow delete: if isAdmin();
    }
  }
}
